---
const { title, text } = Astro.props;
---

<header class="top-header">
  <div>
    <h2
      class="text-2xl font-bold bg-clip-text text-transparent bg-linear-to-r from-indigo-400 to-fuchsia-400"
    >
      {title}
    </h2>
    <p class="text-sm text-gray-400 mt-2 font-medium">
      {text}
    </p>
  </div>
</header>

<style>
  @media (max-width: 768px) {
    .top-header {
      padding-left: calc(24px + var(--sidebar-mini-width));
    }
  }
</style>
