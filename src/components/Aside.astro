---
import HomeIcon from "@/icons/HomeIcon.astro";
import About from "@/icons/AboutIcon.astro";
import Monster from "@/icons/MonsterIcon.astro";
import LevelIcon from "@/icons/LevelIcon.astro";
import MenuIcon from "@/icons/MenuIcon.astro";
import MessageIcon from "@/icons/MessageIcon.astro";
import DiscordIcon from "@/icons/DiscordIcon.astro";
import MailIcon from "@/icons/MailIcon.astro";
import MOSLogo from "@/assets/logo.png";

const discordUrl = "https://discord.com/users/768556441283461190";
const email = "refh4ck.dev@gmail.com";

const asideTabs = [
  { name: "Home", path: "/", icon: HomeIcon, enabled: true },
  { name: "Level Info", path: "/level", icon: About, enabled: true },
  { name: "Bosses", path: "/bosses", icon: Monster, enabled: false },
  {
    name: "Level Calculator Badge",
    path: "/level_calc_badge",
    icon: LevelIcon,
    enabled: false,
  },
];
---

<aside id="sidebar" class="sidebar">
  <div class="sidebar-header">
    <button id="toggle-sidebar" aria-label="Toggle Sidebar">
      <MenuIcon />
    </button>
    <h2 class="sidebar-title">Maple Orbit Station</h2>
  </div>
  <nav class="sidebar-nav flex flex-col">
    <ul class="flex flex-col gap-4">
      {
        asideTabs.map((tab, i) => (
          <li>
            <a
              href={`${tab.enabled ? tab.path : ""}`}
              class={`nav-link flex gap-3 ${tab.enabled ? "" : "opacity-50 cursor-not-allowed"}`}
              title={tab.name}
            >
              <tab.icon class="nav-icon" />
              <span class="nav-text">{tab.name}</span>
            </a>
            {}
          </li>
        ))
      }
    </ul>

    <div class="mt-auto px-3 pb-6 feedback-btn-wrap">
      <button
        id="open-feedback-modal"
        aria-label="Open Features Feedback"
        title="Features Feedback"
        class="group relative overflow-hidden flex w-full items-center py-3 px-3 bg-linear-to-r from-fuchsia-900/40 to-indigo-900/40 border border-fuchsia-500/30 hover:from-fuchsia-600 hover:to-indigo-600 text-white rounded-xl font-bold shadow-[0_0_15px_rgba(217,70,239,0.15)] hover:shadow-[0_0_25px_rgba(217,70,239,0.4)] transition-all duration-300 cursor-pointer"
      >
        <div class="relative shrink-0 w-6 h-6 ml-1">
          <MessageIcon
            class="w-full h-full text-fuchsia-400 group-hover:text-white transition-colors group-hover:scale-110 duration-300"
          />
          <span class="absolute -top-1 -right-1 flex h-2.5 w-2.5">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-fuchsia-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2.5 w-2.5 bg-fuchsia-200"
            ></span>
          </span>
        </div>
        <span
          class="nav-text whitespace-nowrap text-sm font-semibold text-fuchsia-50 group-hover:text-white"
          >Features Feedback</span
        >
      </button>
    </div>
  </nav>
  <footer class="sidebar-footer flex gap-5 items-center border-t border-white/10 w-full p-4">
    <img
      src={MOSLogo?.src}
      alt="Maple Orbit Station logo"
      class="size-16 rounded-full shadow-lg shadow-indigo-100/10 border border-indigo-100/12 shrink-0"
    />
    <p class="nav-text text-lg italic">
      Made by <span class="font-semibold">0xRef</span>
    </p>
  </footer>
</aside>

<div id="feedback-modal" class="feedback-modal-overlay" hidden>
  <div
    class="feedback-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="feedback-modal-title"
  >
    <button
      id="close-feedback-modal"
      class="feedback-modal-close"
      aria-label="Close"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18M6 6l12 12"></path>
      </svg>
    </button>

    <h3 id="feedback-modal-title" class="feedback-modal-title">
      Share your feedback
    </h3>
    <p class="feedback-modal-subtitle">
      Choose how you'd like to suggest a new feature
    </p>

    <div class="feedback-modal-options">
      <a
        href={discordUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="feedback-option feedback-option-discord"
      >
        <div class="feedback-option-icon">
          <DiscordIcon class="w-8 h-8" />
        </div>
        <div class="feedback-option-body">
          <h4>Discord DM</h4>
          <p>Send me a direct message on Discord for a quick chat.</p>
        </div>
        <span class="feedback-option-arrow">→</span>
      </a>

      <a
        href={`mailto:${email}?subject=Feature%20Feedback%20-%20Maple%20Orbit%20Station`}
        class="feedback-option feedback-option-mail"
      >
        <div class="feedback-option-icon">
          <MailIcon class="w-8 h-8" />
        </div>
        <div class="feedback-option-body">
          <h4>Send an Email</h4>
          <p>Write me an email describing your feature idea.</p>
        </div>
        <span class="feedback-option-arrow">→</span>
      </a>
    </div>
  </div>
</div>

<style>
  /* --- Collapsed sidebar responsiveness ---
     Assumes your global CSS already handles the base `.sidebar` width/
     transition and toggles `sidebar-closed` on <html> (as your script does).
     These rules only handle what happens to icons/text in that state. */

  /* ==========================================================
   SIDEBAR
========================================================== */

.sidebar {
  overflow-x: hidden;
  overflow-y: auto;
  transition:
    width .28s cubic-bezier(.4, 0, .2, 1),
    box-shadow .25s ease;
}

/* -----------------------------
   Header
------------------------------ */

.sidebar-header {
  transition: justify-content .25s ease;
}

.sidebar-title {
  width: auto;
  opacity: 1;
  white-space: nowrap;
  overflow: hidden;
  transform: translateX(0);
  transition:
    opacity .2s ease,
    width .25s ease,
    transform .25s ease;
}

/* -----------------------------
   Navigation
------------------------------ */

.nav-link {
  display: flex;
  align-items: center;
  min-height: 48px;
  border-radius: 14px;
  transition:
    background .2s ease,
    transform .2s ease,
    gap .25s ease,
    justify-content .25s ease;
}

.nav-icon {
  width: 24px;
  height: 24px;
  min-width: 24px;
  min-height: 24px;
  flex: 0 0 24px;
  transition: transform .2s ease;
}

.nav-text {
  display: block;
  max-width: 200px;
  white-space: nowrap;
  overflow: hidden;
  opacity: 1;
  transform: translateX(0);
  transition:
    opacity .18s ease,
    transform .22s ease,
    max-width .25s ease;
}

/* -----------------------------
   Footer
------------------------------ */

.sidebar-footer {
  display: flex;
  align-items: center;
  gap: 16px;
  overflow: hidden;
  transition:
    gap .25s ease,
    padding .25s ease,
    justify-content .25s ease;
}

.sidebar-footer p.nav-text {
  max-width: 160px;
}

.sidebar-footer img {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center;
  flex-shrink: 0;
  transition: transform .25s ease;
}

/* -----------------------------
   Feedback Button
------------------------------ */

.feedback-btn-wrap button {
  transition:
    width .25s ease,
    height .25s ease,
    padding .25s ease,
    border-radius .25s ease,
    justify-content .25s ease;
}

.feedback-btn-wrap button > div {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  flex: 0 0 24px;
}

/* ==========================================================
   COLLAPSED SIDEBAR
========================================================== */

:global(html.sidebar-closed) .sidebar {
  width: 80px;
}

:global(html.sidebar-closed) .sidebar-title,
:global(html.sidebar-closed) .nav-text {
  width: 0;
  max-width: 0;
  opacity: 0;
  transform: translateX(-8px);
  pointer-events: none;
}

:global(html.sidebar-closed) .sidebar-header {
  justify-content: center;
}

:global(html.sidebar-closed) .nav-link {
  justify-content: center;
  width: 48px;
  min-width: 48px;
  margin-inline: auto;
  padding-left: 0;
  padding-right: 0;
  gap: 0;
}

:global(html.sidebar-closed) .sidebar-footer {
  justify-content: center;
  gap: 0;
  padding-left: 0;
  padding-right: 0;
}

:global(html.sidebar-closed) .sidebar-footer img {
  transform: scale(.9);
}

:global(html.sidebar-closed) .feedback-btn-wrap button {
  width: 48px;
  min-width: 48px;
  height: 48px;
  justify-content: center;
  padding: 0;
  border-radius: 14px;
}

:global(html.sidebar-closed) .feedback-btn-wrap button > div {
  margin-left: 0;
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggleBtn = document.getElementById("toggle-sidebar");
    const overlay = document.getElementById("overlay");

    const toggleSidebar = () => {
      document.documentElement.classList.toggle("sidebar-closed");
      const isClosed =
        document.documentElement.classList.contains("sidebar-closed");
      localStorage.setItem("sidebarClosed", isClosed.toString());
    };

    if (toggleBtn) {
      toggleBtn.addEventListener("click", toggleSidebar);
    }

    if (overlay) {
      overlay.addEventListener("click", () => {
        document.documentElement.classList.add("sidebar-closed");
        localStorage.setItem("sidebarClosed", "true");
      });
    }

    const feedbackModal = document.getElementById("feedback-modal");
    const openBtn = document.getElementById("open-feedback-modal");
    const closeBtn = document.getElementById("close-feedback-modal");

    const openModal = () => {
      if (!feedbackModal) return;
      feedbackModal.hidden = false;
      requestAnimationFrame(() => {
        feedbackModal.classList.add("is-open");
      });
      document.addEventListener("keydown", onEscKey);
    };

    const closeModal = () => {
      if (!feedbackModal) return;
      feedbackModal.classList.remove("is-open");
      const onEnd = (e: Event) => {
        if (e.target !== feedbackModal) return;
        feedbackModal.hidden = true;
        feedbackModal.removeEventListener("transitionend", onEnd);
      };
      feedbackModal.addEventListener("transitionend", onEnd);
      document.removeEventListener("keydown", onEscKey);
    };

    const onEscKey = (e: KeyboardEvent) => {
      if (e.key === "Escape") closeModal();
    };

    if (openBtn) openBtn.addEventListener("click", openModal);
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (feedbackModal) {
      feedbackModal.addEventListener("click", (e) => {
        if (e.target === feedbackModal) closeModal();
      });
    }
  });
</script>