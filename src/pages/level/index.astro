---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import levelData from '@/lib/static/level_data.json';
import SearchIcon from '@/icons/Search.astro';

const levels = levelData.levels;
const reversedLevels = [...levels].reverse();

function formatExp(value, unit: String) {
	if (value === null || value === undefined) return 'Level Cap';
	const unitSuffix = {
		'units': '',
		'thousands': 'k',
		'millions': 'M',
		'billions': 'B',
		'trillions': 'T'
	};
	const suffix = unitSuffix[unit] !== undefined ? unitSuffix[unit] : (unit === 'units' ? '' : ` ${unit}`);
	return `${value.toLocaleString()}${suffix}`;
}
---

<Layout>

	<main class="w-full h-[calc(100dvh)]">
		<div class="relative w-full h-full flex flex-col bg-white shadow-[0_0_30px_rgba(62,55,118,0.08)] overflow-hidden">

			<!-- Subtle glowing orbs -->
			<div class="absolute -top-24 -right-24 w-96 h-96 bg-[#3e3776]/10 rounded-full blur-3xl pointer-events-none"></div>
			<div class="absolute -bottom-24 -left-24 w-96 h-96 bg-[#e7ff48]/10 rounded-full blur-3xl pointer-events-none"></div>

			<section class="relative px-8 py-6  bg-[#3e3776]">
				<article class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
					<div>
						<h2 class="text-2xl font-bold tracking-wide text-white drop-shadow-[0_0_8px_rgba(231,255,72,0.3)]">Experience Progression</h2>
						<p class="text-sm text-[#dbed4efe] mt-2 font-medium">Detailed breakdown of EXP requirements from Level 1 to {levels[levels.length - 1].lvl}</p>
					</div>
					<div class="flex items-center gap-4">
						<div class="relative">
							<div class="absolute inset-y-0 left-0 flex items-center z-10 pl-3 pointer-events-none">
								<SearchIcon class="w-4 h-4 text-[#3e3776]" />
							</div>
							<input type="text" id="level-search" class="block w-full sm:w-64 p-2.5 pl-10 text-sm text-[#0c0058] bg-white/90 border border-[#2826261a] rounded-xl focus:ring-2 focus:ring-[#3e3776]/40 focus:border-[#3e3776] placeholder-[#28262699] transition-all focus:bg-white outline-none shadow-sm" placeholder="Search level (e.g. 100)">
						</div>
					</div>
				</article>
			</section>

			<section class="relative flex-1 overflow-auto custom-scrollbar">
				<table class="w-full min-w-160 text-left border-collapse">
					<thead class="sticky top-0 bg-white/95 backdrop-blur-sm z-10">
						<tr>
							<th class="py-4 px-8 text-xs font-bold text-[#0c0058] uppercase tracking-widest border-b-2 border-[#3e3776]/40 w-32">Level</th>
							<th class="py-4 px-8 text-xs font-bold text-[#0c0058] uppercase tracking-widest border-b-2 border-[#3e3776]/40">EXP to Next Level</th>
							<th class="py-4 px-8 text-xs font-bold text-[#0c0058] uppercase tracking-widest border-b-2 border-[#3e3776]/40 text-right">Cumulative EXP</th>
						</tr>
					</thead>
					<tbody>
						{reversedLevels.map((level, i) => (
							<tr
								class:list={[
									'level-row group transition-colors duration-150 border-b border-[#2826260f] hover:bg-[#3e3776]/5',
									i % 2 === 0 ? 'bg-[#28262605]' : 'bg-transparent'
								]}
								data-level={level.lvl}
							>
								<td class="py-4 px-8 whitespace-nowrap">
									<div class="flex items-center gap-4">
										<div class="flex items-center justify-center w-11 h-11 rounded-xl bg-linear-to-br from-[#3e3776]/15 to-[#e7ff48]/15 text-[#0c0058] font-bold text-base border border-[#3e3776]/20 shadow-[0_0_12px_rgba(62,55,118,0.1)] group-hover:scale-105 group-hover:from-[#3e3776] group-hover:to-[#bdcb4e] group-hover:text-white transition-all duration-200">
											{level.lvl}
										</div>
									</div>
								</td>
								<td class="py-4 px-8 whitespace-nowrap text-[#282626e5] font-mono text-base group-hover:text-[#0c0058] transition-colors">
									<span class="bg-[#28262608] px-3 py-1.5 rounded-lg border border-[#2826261a]">
										{formatExp(level.exp, level.units)}
									</span>
								</td>
								<td class="py-4 px-8 whitespace-nowrap font-mono text-base text-right">
									<span class="font-semibold bg-linear-to-r from-[#3e3776]/15 to-transparent px-4 py-1.5 rounded-lg text-[#0c0058] group-hover:text-[#3e3776] transition-colors border-l-2 border-[#3e3776]/40">
										{formatExp(level.cumulative_exp, level.units)}
									</span>
								</td>
							</tr>
						))}
					</tbody>
				</table>

				<p id="no-results" class="hidden text-center text-[#28262699] text-sm py-10">
					No levels match your search.
				</p>
			</section>
		</div>
	</main>

	<style>
		.custom-scrollbar::-webkit-scrollbar {
			width: 10px;
			height: 10px;
		}
		.custom-scrollbar::-webkit-scrollbar-track {
			background: rgba(62, 55, 118, 0.05);
			border-radius: 4px;
		}
		.custom-scrollbar::-webkit-scrollbar-thumb {
			background: rgba(62, 55, 118, 0.2);
			border-radius: 4px;
		}
		.custom-scrollbar::-webkit-scrollbar-thumb:hover {
			background: rgba(62, 55, 118, 0.35);
		}
	</style>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const searchInput = document.getElementById('level-search') as HTMLInputElement;
			const tableRows = document.querySelectorAll('.level-row') as NodeListOf<HTMLElement>;
			const noResults = document.getElementById('no-results') as HTMLElement;

			if (searchInput) {
				searchInput.addEventListener('input', (e) => {
					const searchTerm = (e.target as HTMLInputElement).value.trim();
					let visibleCount = 0;

					tableRows.forEach(row => {
						if (!searchTerm) {
							row.style.display = '';
							visibleCount++;
							return;
						}

						const level = row.getAttribute('data-level');
						if (level && level.includes(searchTerm)) {
							row.style.display = '';
							visibleCount++;
						} else {
							row.style.display = 'none';
						}
					});

					noResults.classList.toggle('hidden', visibleCount !== 0);
				});
			}
		});
	</script>
</Layout>
