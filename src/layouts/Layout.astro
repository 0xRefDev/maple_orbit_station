---
import "@/styles/global.css";
import Aside from "@/components/Aside.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.ico" />
    <link rel="icon" href="/logo.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>MOS | Maple Orbit Station</title>

    <script is:inline>
      const isClosed = localStorage.getItem("sidebarClosed") === "true";
      if (isClosed) {
        document.documentElement.classList.add("sidebar-closed");
      }
    </script>
  </head>
  <body>
    <div class="app-container">
      <Aside />
      <div class="content-wrapper relative">
				<main class="overflow-y-auto">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --sidebar-width: 290px;
    --sidebar-mini-width: 72px;
    --header-height: 64px;
    --transition-speed: 0.3s;
    --bg-color: #2a2a3c;
    --sidebar-bg: #191926;
    --sidebar-text: #ffffff;
    --sidebar-hover: rgba(255, 255, 255, 0.1);
    --header-bg: #1e1d28c4;
    --text-color: #333333;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    background-color: var(--bg-color);
    color: var(--text-color);
  }

  .app-container {
    display: flex;
    height: 100vh;
    overflow: hidden;
    position: relative;
  }

  .sidebar {
    width: var(--sidebar-width);
    background-color: var(--sidebar-bg);
    color: var(--sidebar-text);
    transition: width var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
    height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    position: relative;
    z-index: 20;
    box-shadow: 2px 0 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
  }

  html.sidebar-closed .sidebar {
    width: var(--sidebar-mini-width);
  }

  .sidebar-header {
    height: var(--header-height);
    padding: 0 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-sizing: border-box;
    overflow: hidden;
    flex-shrink: 0;
  }

  #toggle-sidebar {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sidebar-text);
    border-radius: 6px;
    transition: background-color 0.2s;
    min-width: 40px;
    height: 40px;
  }

  #toggle-sidebar:hover {
    background-color: var(--sidebar-hover);
  }

  .sidebar-title {
    margin: 0 0 0 12px;
    font-size: 1.25rem;
    white-space: nowrap;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: opacity 0.2s ease;
  }

  html.sidebar-closed .sidebar-title {
    opacity: 0;
    pointer-events: none;
  }

  .sidebar-nav {
    flex-grow: 1;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 16px 0;
    margin: 0;
  }

  .sidebar-nav ul li a {
    display: flex;
    align-items: center;
    padding: 12px 24px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
    white-space: nowrap;
    font-weight: 500;
  }

  .sidebar-nav ul li a:hover {
    background-color: var(--sidebar-hover);
    color: #fff;
  }

  .nav-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
  }

  .nav-text {
    margin-left: 16px;
    transition: opacity 0.2s ease;
  }

  html.sidebar-closed .nav-text {
    opacity: 0;
    pointer-events: none;
  }

  .content-wrapper {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    transition: width var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 768px) {
    .sidebar {
      position: absolute;
      transform: translateX(0);
      width: var(--sidebar-width);
      transition: transform var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    }

    html.sidebar-closed .sidebar {
      transform: translateX(0);
      width: var(--sidebar-mini-width);
    }

    html:not(.sidebar-closed) .overlay {
      display: block;
      opacity: 1;
    }

    .main-content {
      padding: 16px;
      padding-left: calc(16px + var(--sidebar-mini-width));
    }
  }
</style>
